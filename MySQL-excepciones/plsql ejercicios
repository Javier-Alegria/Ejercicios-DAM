/*Pide un numero y escribe su tabla de multiplicar 08/04/2026*/
set serveroutput on;

declare 

    numero number;
    contador number;
    
begin

    numero:=&introduce_un_numero;
    
    for contador in 1..10 loop
        dbms_output.put_line(numero||' x '||contador||' = '||numero*contador);
    end loop;
end;


/*Leer dos números enteros y deicr si son iguales y en caso contrario, cuál es mayor de los dos 09/04/2026*/
set serveroutput on;
declare
    a INTEGER :=&num_1;
    b INTEGER :=&num_2;
begin
    if (a=b) then
        dbms_output.put_line('Los números son iguales');
    else
        if (a>b) then
            dbms_output.put_line('el '||a||' es mayor que el '||b);
        else
            dbms_output.put_line('a: '||a||' es menor que b: '||b);
        end if;
    end if;
end;

