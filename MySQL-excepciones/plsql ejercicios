/* Mostrar el nombre de las ciudades de españa
CURSOR EXPLÍCITO 1 SQL */
set serveroutput on;
declare

-- Declar el cursor
cursor c1 is 
    select c.nombre as ciudad
    from pais p join ciudad c
    on p.cod_pais=c.cod_pais
    where p.nombre like 'España';

-- declarar variables para el volcado, en este caso, para el nombre de la ciudad
nomciudad varchar2(20);

begin

-- si el cursor no esta abierto, abrelo
if not c1 %ISOPEN then
    open c1;
end if;

-- empieza el bucle principal
loop 
    --volcar primera fila
    fetch c1 into nomciudad;
    -- sal cuando c1 no tenga datos
    exit when c1%NOTFOUND;
    -- si tiene datos, hacer el tratamiento de las filas
    dbms_output.put_line(nomciudad);
end loop;
-- cerrar el cursor
close c1;
end;

/* Mostrar los países europeos y sus capitales */
