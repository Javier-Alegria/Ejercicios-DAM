/* CURSOR EXPLÍCITO 4 (DE ACTUALIZACIÓN)
recibir nombre de continente y un tanto porciento (entre 0 y 1) y suba el PIB de los paises de ese continente en ese porcentaje */
set serveroutput on;
declare

-- Declar el cursor
cursor c1(continentee VARCHAR2) is 
    select nombre
    from pais
    where continente like continentee
    for update;

-- declarar un atributo compuesto utilizando rowtype
reg_pais c1%rowtype;
nomcon varchar2(20);
porcentaje number;

begin

nomcon := &Introduce_nombre_continente;
porcentaje := &introduce_un_porcentaje;



-- si el cursor no esta abierto, abrelo
if not c1 %ISOPEN then
    open c1(nomcon);
end if;

-- empieza el bucle principal
loop 
    --volcar primera fila
    fetch c1 into reg_pais;
    -- sal cuando c1 no tenga datos
    exit when c1%NOTFOUND;
    -- si tiene datos, subir el pib de los continentes
    update pais set pib = pib * (1 + porcentaje/100) where current of c1;
end loop;

-- cerrar el cursor
close c1;
commit;
end;
